# Normalize EOL for all files that Git considers text files.
* text=auto eol=crlf

# Treat common Godot and media assets as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.svg binary
*.ico binary
*.mp3 binary
*.wav binary
*.ogg binary
*.ttf binary
*.otf binary
*.dll binary

# Keep asset-store/archive exports focused on the sample project and plugin folder.
.editorconfig export-ignore
.github export-ignore
.gitignore export-ignore
.godot export-ignore
.vs export-ignore
DotPudicaFramework.csproj export-ignore
DotPudicaFramework.sln export-ignore
LICENSE export-ignore
project.godot export-ignore
README.md export-ignore
README_CN.md export-ignore
